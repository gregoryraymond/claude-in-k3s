ARG BASE_IMAGE

FROM ${BASE_IMAGE}

# Install curl + ca-certificates if missing (needed for Claude Code installer)
RUN if ! command -v curl >/dev/null 2>&1; then \
        apt-get update && apt-get install -y --no-install-recommends \
            curl ca-certificates && \
        rm -rf /var/lib/apt/lists/*; \
    fi

# Ensure a user with UID 1000 exists
RUN if ! id -u 1000 >/dev/null 2>&1; then \
        useradd -m -s /bin/bash -u 1000 claude; \
    fi

# Install Claude Code via native installer and copy to a global path
USER root
RUN bash -c 'set -e && \
    curl -fsSL https://claude.ai/install.sh | bash && \
    source ~/.bashrc 2>/dev/null || true && \
    CLAUDE_BIN=$(which claude 2>/dev/null || \
        find / -maxdepth 8 -name "claude" \( -type f -o -type l \) -executable \
            -not -path "*/downloads/*" 2>/dev/null | head -1) && \
    if [ -n "$CLAUDE_BIN" ] && [ "$CLAUDE_BIN" != "/usr/local/bin/claude" ]; then \
        cp -L "$CLAUDE_BIN" /usr/local/bin/claude && chmod +x /usr/local/bin/claude; \
    fi && \
    /usr/local/bin/claude --version'

# Pre-configure Claude to skip onboarding and trust /workspace
RUN bash -c 'USER_HOME=$(eval echo "~$(id -nu 1000)") && \
    mkdir -p "$USER_HOME/.claude" && \
    echo '"'"'{"hasCompletedOnboarding": true, "projects": {"/workspace": {"allowedTools": [], "hasTrustDialogAccepted": true}}}'"'"' > "$USER_HOME/.claude.json" && \
    chown -R 1000:1000 "$USER_HOME/.claude" "$USER_HOME/.claude.json"'
