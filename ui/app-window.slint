import { Theme } from "theme.slint";
import { NavItem } from "components/nav-item.slint";
import { Card } from "components/card.slint";
import { IconButton } from "components/icon-button.slint";
import { StatusBadge } from "components/status-badge.slint";
import { FormField } from "components/form-field.slint";
import { ClusterPanel } from "components/cluster-panel.slint";
import { ProjectsPanel, ProjectEntry, LaunchTab, LaunchStep } from "components/projects-panel.slint";
import { PodsPanel, PodEntry } from "components/pods-panel.slint";
import { SetupPanel } from "components/setup-panel.slint";
import { ToastOverlay, ToastEntry } from "components/toast.slint";
import { ScrollView, ComboBox } from "std-widgets.slint";

export { ProjectEntry, PodEntry, LaunchTab, LaunchStep, ToastEntry }

export component AppWindow inherits Window {
    title: "Claude in K3s";
    min-width: 900px;
    min-height: 650px;
    preferred-width: 1024px;
    preferred-height: 768px;
    background: Theme.bg;

    in-out property <int> active-page: 1;

    in property <string> cluster-status: "Unknown";
    in property <string> docker-status: "Unknown";
    in property <string> containers-status: "Unknown";
    in property <string> node-status: "Unknown";
    in property <string> helm-release-status: "Unknown";
    in property <string> memory-usage-text: "";
    in property <int> memory-percent: 0;
    in property <string> cluster-detail: "";
    in property <string> helm-detail: "";
    in property <string> docker-detail: "";
    in property <string> wsl-status: "Unknown";
    in property <string> recovery-hint: "";
    in property <string> cluster-log: "";
    in property <bool> is-busy: false;
    in property <bool> tf-initialized: false;

    in property <string> projects-dir: "";
    in-out property <[ProjectEntry]> projects: [];

    in property <[PodEntry]> pods: [];
    in property <string> pod-log: "";


    in property <string> platform-name: "Linux";
    in-out property <string> claude-mode: "daemon";
    in-out property <string> git-user-name: "Claude Code Bot";
    in-out property <string> git-user-email: "claude-bot@localhost";
    in-out property <string> cpu-limit: "2";
    in-out property <string> memory-limit: "4Gi";
    in-out property <string> cluster-memory-percent: "80";
    in property <string> cluster-memory-info: "";
    in-out property <string> terraform-dir: "terraform";
    in-out property <string> helm-chart-dir: "helm/claude-code";
    // SET-12: Extra host mounts (comma-separated paths)
    in-out property <string> extra-mounts-text: "";

    in property <bool> all-deps-met: true;
    in property <bool> k3s-found: false;
    in property <bool> terraform-found: false;
    in property <bool> helm-found: false;
    in property <bool> docker-found: false;
    in property <string> k3s-label: "k3s";
    in property <string> k3s-version: "";
    in property <string> terraform-version: "";
    in property <string> helm-version: "";
    in property <string> docker-version: "";
    in property <string> install-log: "";
    in property <bool> is-installing: false;

    in property <bool> claude-found: false;
    in property <string> claude-version: "";

    in property <bool> all-selected: false;
    in property <[LaunchTab]> launch-tabs: [];
    in-out property <int> active-launch-tab: 0;
    in property <[LaunchStep]> launch-steps: [];

    callback cluster-deploy();
    callback terraform-destroy();
    callback terraform-plan();
    callback helm-status();
    callback restart-wsl();
    callback restart-docker();
    callback restart-cluster();

    callback browse-folder();
    callback refresh-projects();
    callback launch-selected();
    callback stop-selected();
    callback cancel-launch();
    callback toggle-select-all();
    callback project-toggled(int, bool);
    callback project-image-changed(int, int);
    callback retry-build(string);

    callback refresh-pods();
    callback delete-pod(int);
    callback view-logs(int);
    callback exec-claude(int);
    callback shell-pod(int);
    callback toggle-network(int);
    callback pod-toggled(int, bool);
    callback toggle-select-all-pods(bool);
    callback delete-selected-pods();
    callback redeploy-selected();
    callback expose-selected();
    callback unexpose-selected();

    in property <bool> all-pods-selected: false;
    in property <int> selected-pod-count: 0;
    in property <string> selected-pod-names: "";

    callback save-settings();
    in property <string> settings-error: "";

    // Toast notification system (ERR-2, ERR-3, ERR-4, ERR-5)
    in property <[ToastEntry]> toasts: [];
    // show-toast(message, level, target-page) — target-page: -1 = no nav
    callback show-toast(string, string, int);
    callback dismiss-toast(int);

    callback install-missing();
    callback continue-app();

    // Main content layer + toast overlay, stacked via implicit z-order
    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 180px;
            background: Theme.surface-alt;

            VerticalLayout {
                padding-top: 16px;
                spacing: 0px;

                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    padding-bottom: 20px;
                    spacing: 8px;

                    Text {
                        text: "CK3";
                        font-size: 24px;
                        font-weight: 800;
                        color: Theme.accent;
                        vertical-alignment: center;
                    }

                    Text {
                        text: "Claude in K3s";
                        font-size: 11px;
                        color: Theme.text-muted;
                        vertical-alignment: center;
                    }
                }

                Rectangle { height: 1px; background: Theme.border; }

                NavItem {
                    icon-source: @image-url("icons/cluster.svg");
                    label: "Cluster";
                    active: active-page == 0;
                    clicked => { active-page = 0; }
                }

                NavItem {
                    icon-source: @image-url("icons/projects.svg");
                    label: "Projects";
                    active: active-page == 1;
                    clicked => { active-page = 1; }
                }

                NavItem {
                    icon-source: @image-url("icons/pods.svg");
                    label: "Pods";
                    active: active-page == 2;
                    clicked => { active-page = 2; }
                }

                Rectangle { vertical-stretch: 1; }

                Rectangle { height: 1px; background: Theme.border; }

                NavItem {
                    icon-source: @image-url("icons/settings.svg");
                    label: "Settings";
                    active: active-page == 3;
                    clicked => { active-page = 3; }
                }

                Rectangle { height: 12px; }
            }
        }

        Rectangle {
            width: 1px;
            background: Theme.border;
        }

        Rectangle {
            horizontal-stretch: 1;
            background: Theme.bg;

            if !all-deps-met : SetupPanel {
                k3s-found: root.k3s-found;
                terraform-found: root.terraform-found;
                helm-found: root.helm-found;
                docker-found: root.docker-found;
                claude-found: root.claude-found;
                k3s-label: root.k3s-label;
                k3s-version: root.k3s-version;
                terraform-version: root.terraform-version;
                helm-version: root.helm-version;
                docker-version: root.docker-version;
                claude-version: root.claude-version;
                install-log: root.install-log;
                is-installing: root.is-installing;
                platform-name: root.platform-name;
                install-missing => { root.install-missing(); }
                continue-app => { root.continue-app(); }
            }

            if all-deps-met && active-page == 0 : ClusterPanel {
                cluster-status: root.cluster-status;
                docker-status: root.docker-status;
                containers-status: root.containers-status;
                node-status: root.node-status;
                helm-release-status: root.helm-release-status;
                memory-usage-text: root.memory-usage-text;
                memory-percent: root.memory-percent;
                cluster-detail: root.cluster-detail;
                helm-detail: root.helm-detail;
                docker-detail: root.docker-detail;
                wsl-status: root.wsl-status;
                recovery-hint: root.recovery-hint;
                k3s-label: root.k3s-label;
                platform-name: root.platform-name;
                pods: root.pods;
                log-output: root.cluster-log;
                is-busy: root.is-busy;
                tf-initialized: root.tf-initialized;
                cluster-deploy => { root.cluster-deploy(); }
                terraform-destroy => { root.terraform-destroy(); }
                terraform-plan => { root.terraform-plan(); }
                helm-status => { root.helm-status(); }
                restart-wsl => { root.restart-wsl(); }
                restart-docker => { root.restart-docker(); }
                restart-cluster => { root.restart-cluster(); }
            }

            if all-deps-met && active-page == 1 : ProjectsPanel {
                projects-dir: root.projects-dir;
                projects: root.projects;
                is-busy: root.is-busy;
                launch-log: root.cluster-log;
                all-selected: root.all-selected;
                launch-tabs: root.launch-tabs;
                active-launch-tab <=> root.active-launch-tab;
                launch-steps: root.launch-steps;
                browse-folder => { root.browse-folder(); }
                refresh-projects => { root.refresh-projects(); }
                launch-selected => { root.launch-selected(); }
                stop-selected => { root.stop-selected(); }
                cancel-launch => { root.cancel-launch(); }
                toggle-select-all => { root.toggle-select-all(); }
                project-toggled(idx, checked) => { root.project-toggled(idx, checked); }
                project-image-changed(idx, img) => { root.project-image-changed(idx, img); }
                retry-build(label) => { root.retry-build(label); }
            }

            if all-deps-met && active-page == 2 : PodsPanel {
                pods: root.pods;
                is-busy: root.is-busy;
                pod-log: root.pod-log;
                all-pods-selected: root.all-pods-selected;
                selected-pod-count: root.selected-pod-count;
                selected-names: root.selected-pod-names;
                refresh-pods => { root.refresh-pods(); }
                delete-pod(idx) => { root.delete-pod(idx); }
                view-logs(idx) => { root.view-logs(idx); }
                exec-claude(idx) => { root.exec-claude(idx); }
                shell-pod(idx) => { root.shell-pod(idx); }
                toggle-network(idx) => { root.toggle-network(idx); }
                pod-toggled(idx, checked) => { root.pod-toggled(idx, checked); }
                toggle-select-all-pods(checked) => { root.toggle-select-all-pods(checked); }
                delete-selected-pods => { root.delete-selected-pods(); }
                redeploy-selected => { root.redeploy-selected(); }
                expose-selected => { root.expose-selected(); }
                unexpose-selected => { root.unexpose-selected(); }
            }

            if all-deps-met && active-page == 3 : Rectangle {
                background: Theme.bg;

                ScrollView {
                    VerticalLayout {
                        padding: 24px;
                        spacing: 16px;

                        Text {
                            text: "Settings";
                            font-size: 24px;
                            font-weight: 700;
                            color: Theme.text;
                        }

                        Card {
                            title: "Claude Mode";
                            VerticalLayout {
                                spacing: 4px;
                                Text { text: "Mode"; font-size: 12px; font-weight: 500; color: Theme.text-muted; }
                                ComboBox {
                                    model: ["daemon", "headless"];
                                    current-value <=> root.claude-mode;
                                }
                            }
                        }

                        Card {
                            title: "Git Configuration";
                            VerticalLayout {
                                spacing: 12px;
                                FormField { label: "User Name"; text <=> root.git-user-name; placeholder: "Claude Code Bot"; }
                                FormField { label: "Email"; text <=> root.git-user-email; placeholder: "claude-bot@localhost"; }
                            }
                        }

                        Card {
                            title: "Resource Limits";
                            VerticalLayout {
                                spacing: 12px;
                                FormField { label: "CPU Limit"; text <=> root.cpu-limit; placeholder: "2"; }
                                FormField { label: "Memory"; text <=> root.memory-limit; placeholder: "4Gi"; }
                                FormField { label: "Cluster Memory %"; text <=> root.cluster-memory-percent; placeholder: "80"; }
                                Text { text: root.cluster-memory-info; font-size: 11px; color: Theme.text-muted; }
                            }
                        }

                        Card {
                            title: "Directories";
                            VerticalLayout {
                                spacing: 12px;
                                FormField { label: "Terraform Directory"; text <=> root.terraform-dir; placeholder: "terraform"; }
                                FormField { label: "Helm Chart Directory"; text <=> root.helm-chart-dir; placeholder: "helm/claude-code"; }
                            }
                        }

                        Card {
                            title: "Extra Mounts";
                            VerticalLayout {
                                spacing: 4px;
                                FormField { label: "Host Paths (comma-separated)"; text <=> root.extra-mounts-text; placeholder: "/data/shared, /opt/tools"; }
                                Text { text: "Additional host directories to mount into pods."; font-size: 11px; color: Theme.text-muted; }
                            }
                        }

                        Card {
                            title: "Platform Info";
                            Text { text: "Detected platform: " + root.platform-name; font-size: 13px; color: Theme.text; }
                        }

                        IconButton {
                            label: "Save Settings";
                            primary: true;
                            clicked => { root.save-settings(); }
                        }

                        Rectangle { vertical-stretch: 1; }
                    }
                }
            }
        }
    }

    // Toast overlay — rendered on top of all content (ERR-2, ERR-3, ERR-4, ERR-5)
    ToastOverlay {
        toasts: root.toasts;
        dismiss-toast(id) => { root.dismiss-toast(id); }
        // ERR-5: Navigate to target page when toast body is clicked
        toast-navigate(page) => { root.active-page = page; }
    }
}
