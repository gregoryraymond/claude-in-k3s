import { Theme } from "../theme.slint";
import { Card } from "card.slint";
import { IconButton } from "icon-button.slint";
import { StatusBadge } from "status-badge.slint";
import { LogViewer } from "log-viewer.slint";

export component ClusterPanel inherits Rectangle {
    in property <string> cluster-status: "Unknown";
    in property <string> docker-status: "Unknown";
    in property <string> containers-status: "Unknown";
    in property <string> k3s-label: "k3s";
    in property <string> log-output: "";
    in property <bool> is-busy: false;
    in property <bool> tf-initialized: false;

    private property <bool> show-advanced: false;

    callback cluster-deploy();
    callback terraform-destroy();
    callback terraform-plan();
    callback helm-status();

    background: Theme.bg;

    VerticalLayout {
        padding: 24px;
        spacing: 16px;

        HorizontalLayout {
            spacing: 12px;
            alignment: start;

            Text {
                text: "Cluster";
                font-size: 24px;
                font-weight: 700;
                color: Theme.text;
                vertical-alignment: center;
            }

            StatusBadge { status: cluster-status; }
        }

        HorizontalLayout {
            spacing: 8px;
            alignment: start;

            IconButton {
                label: cluster-status == "Healthy" ? "Redeploy" : "Deploy";
                primary: true;
                enabled: !is-busy;
                clicked => { root.cluster-deploy(); }
            }

            IconButton {
                label: show-advanced ? "Hide Advanced" : "Advanced";
                enabled: true;
                clicked => { show-advanced = !show-advanced; }
            }
        }

        Card {
            title: "Stack Status";

            VerticalLayout {
                spacing: 8px;

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "Docker"; font-size: 13px; color: Theme.text; horizontal-stretch: 1; }
                    StatusBadge { status: docker-status; width: 100px; }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "Cluster (" + k3s-label + ")"; font-size: 13px; color: Theme.text; horizontal-stretch: 1; }
                    StatusBadge { status: cluster-status; width: 100px; }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "Containers"; font-size: 13px; color: Theme.text; horizontal-stretch: 1; }
                    StatusBadge { status: containers-status; width: 100px; }
                }
            }
        }

        if show-advanced : Card {
            title: "Terraform";

            HorizontalLayout {
                spacing: 8px;
                alignment: start;

                IconButton {
                    label: "Plan";
                    enabled: !is-busy && tf-initialized;
                    clicked => { root.terraform-plan(); }
                }
                IconButton {
                    label: "Destroy";
                    destructive: true;
                    enabled: !is-busy && tf-initialized;
                    clicked => { root.terraform-destroy(); }
                }
            }
        }

        if show-advanced : Card {
            title: "Helm Release";

            HorizontalLayout {
                spacing: 8px;
                alignment: start;

                IconButton {
                    label: "Status";
                    enabled: !is-busy;
                    clicked => { root.helm-status(); }
                }
            }
        }

        if show-advanced : LogViewer {
            text: root.log-output;
            vertical-stretch: 1;
        }
    }
}
