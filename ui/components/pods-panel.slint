import { Theme } from "../theme.slint";
import { Card } from "card.slint";
import { IconButton } from "icon-button.slint";
import { StatusBadge } from "status-badge.slint";
import { DataRow } from "data-row.slint";
import { LogViewer } from "log-viewer.slint";
import { ScrollView, CheckBox } from "std-widgets.slint";

export struct PodEntry {
    name: string,
    project: string,
    phase: string,
    ready: bool,
    restart-count: int,
    age: string,
    warnings: string,
    exposed: bool,
    container-port: int,
    selected: bool,
    remote-control: bool,
}

export component PodsPanel inherits Rectangle {
    in property <[PodEntry]> pods: [];
    in property <bool> is-busy: false;
    in property <string> pod-log: "";

    callback refresh-pods();
    callback delete-pod(int);
    callback view-logs(int);
    callback exec-claude(int);
    callback shell-pod(int);
    callback toggle-network(int);
    callback pod-toggled(int, bool);
    callback toggle-select-all-pods(bool);
    callback delete-selected-pods();
    callback redeploy-selected();
    callback expose-selected();
    callback unexpose-selected();
    in property <bool> all-pods-selected: false;
    in property <int> selected-pod-count: 0;
    in property <string> selected-names: "";

    background: Theme.bg;

    VerticalLayout {
        padding: 24px;
        spacing: 16px;

        HorizontalLayout {
            spacing: 12px;
            alignment: space-between;

            Text {
                text: "Pods";
                font-size: 24px;
                font-weight: 700;
                color: Theme.text;
                vertical-alignment: center;
            }

            IconButton {
                label: "Refresh";
                enabled: !is-busy;
                clicked => { root.refresh-pods(); }
            }
        }

        // Selection action bar
        if selected-pod-count > 0 : Rectangle {
            background: Theme.surface-alt;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.accent;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 8px;
                padding-top: 6px;
                padding-bottom: 6px;
                spacing: 8px;
                alignment: space-between;

                HorizontalLayout {
                    spacing: 6px;

                    Text {
                        text: selected-pod-count + " selected";
                        font-size: 12px;
                        font-weight: 700;
                        color: Theme.text;
                        vertical-alignment: center;
                    }

                    Text {
                        text: "(" + root.selected-names + ")";
                        font-size: 11px;
                        color: Theme.text-muted;
                        vertical-alignment: center;
                        overflow: elide;
                        max-width: 300px;
                    }
                }

                HorizontalLayout {
                    spacing: 4px;

                    IconButton {
                        icon-source: @image-url("../icons/redeploy.svg");
                        compact: true;
                        tooltip: "Redeploy";
                        enabled: !is-busy;
                        clicked => { root.redeploy-selected(); }
                    }

                    IconButton {
                        icon-source: @image-url("../icons/network.svg");
                        compact: true;
                        tooltip: "Expose";
                        enabled: !is-busy;
                        clicked => { root.expose-selected(); }
                    }

                    IconButton {
                        icon-source: @image-url("../icons/network.svg");
                        compact: true;
                        tooltip: "Unexpose";
                        primary: true;
                        enabled: !is-busy;
                        clicked => { root.unexpose-selected(); }
                    }

                    IconButton {
                        icon-source: @image-url("../icons/delete.svg");
                        compact: true;
                        tooltip: "Delete";
                        destructive: true;
                        enabled: !is-busy;
                        clicked => { root.delete-selected-pods(); }
                    }
                }
            }
        }

        // Column headers
        HorizontalLayout {
            spacing: 8px;
            height: 28px;
            padding-left: 12px;
            padding-right: 12px;

            CheckBox {
                width: 28px;
                checked: root.all-pods-selected;
                toggled => { root.toggle-select-all-pods(self.checked); }
            }

            Text { text: "Project"; font-weight: 600; horizontal-stretch: 1; font-size: 11px; color: Theme.text-muted; vertical-alignment: center; }
            Text { text: "Status"; font-weight: 600; width: 84px; font-size: 11px; color: Theme.text-muted; horizontal-alignment: center; vertical-alignment: center; }
            Text { text: "Ready"; font-weight: 600; width: 44px; font-size: 11px; color: Theme.text-muted; horizontal-alignment: center; vertical-alignment: center; }
            Text { text: "Restarts"; font-weight: 600; width: 54px; font-size: 11px; color: Theme.text-muted; horizontal-alignment: center; vertical-alignment: center; }
            Text { text: "Age"; font-weight: 600; width: 72px; font-size: 11px; color: Theme.text-muted; horizontal-alignment: center; vertical-alignment: center; }
            Text { text: "Warnings"; font-weight: 600; width: 120px; font-size: 11px; color: Theme.text-muted; vertical-alignment: center; }
            Text { text: "Port"; font-weight: 600; width: 64px; font-size: 11px; color: Theme.text-muted; horizontal-alignment: center; vertical-alignment: center; }
            Text { text: "Actions"; font-weight: 600; width: 164px; font-size: 11px; color: Theme.text-muted; horizontal-alignment: center; vertical-alignment: center; }
        }

        Rectangle { height: 1px; background: Theme.border; }

        ScrollView {
            vertical-stretch: 1;
            min-height: 200px;

            VerticalLayout {
                spacing: 0px;

                for pod[idx] in pods: Rectangle {
                    background: mod(idx, 2) == 1 ? Theme.surface-alt : transparent;

                    HorizontalLayout {
                        spacing: 8px;
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 6px;
                        padding-bottom: 6px;

                        CheckBox {
                            width: 28px;
                            checked: pod.selected;
                            toggled => { root.pod-toggled(idx, self.checked); }
                        }

                        Text {
                            text: pod.project;
                            horizontal-stretch: 1;
                            font-size: 13px;
                            color: Theme.text;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        HorizontalLayout {
                            width: 84px;
                            alignment: center;
                            vertical-stretch: 0;
                            StatusBadge { status: pod.phase; }
                        }

                        Text {
                            text: pod.ready ? "Yes" : "No";
                            width: 44px;
                            font-size: 13px;
                            color: pod.ready ? Theme.success : Theme.error;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: pod.restart-count;
                            width: 54px;
                            font-size: 13px;
                            color: pod.restart-count > 3 ? Theme.error : Theme.text;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: pod.age;
                            width: 72px;
                            font-size: 13px;
                            color: Theme.text-muted;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            overflow: elide;
                        }

                        Text {
                            text: pod.warnings;
                            width: 120px;
                            font-size: 11px;
                            color: pod.warnings != "" ? Theme.warning : Theme.text-muted;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        Text {
                            text: pod.exposed && pod.container-port > 0 ? ":" + pod.container-port : pod.exposed ? "exposed" : "-";
                            width: 64px;
                            font-size: 12px;
                            color: pod.exposed ? Theme.success : Theme.text-muted;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        HorizontalLayout {
                            width: 164px;
                            spacing: 4px;
                            alignment: center;

                            IconButton {
                                icon-source: @image-url("../icons/log.svg");
                                compact: true;
                                tooltip: "Logs";
                                clicked => { root.view-logs(idx); }
                            }

                            IconButton {
                                icon-source: @image-url("../icons/terminal.svg");
                                compact: true;
                                tooltip: "Claude Code";
                                clicked => { root.shell-pod(idx); }
                            }

                            IconButton {
                                icon-source: @image-url("../icons/claude-icon.svg");
                                compact: true;
                                tooltip: pod.remote-control ? "Stop Remote Control" : "Start Remote Control";
                                active: pod.remote-control;
                                clicked => { root.exec-claude(idx); }
                            }

                            IconButton {
                                icon-source: @image-url("../icons/network.svg");
                                compact: true;
                                tooltip: pod.exposed ? "Unexpose" : "Expose";
                                active: pod.exposed;
                                clicked => { root.toggle-network(idx); }
                            }

                            IconButton {
                                icon-source: @image-url("../icons/delete.svg");
                                compact: true;
                                tooltip: "Delete";
                                destructive: true;
                                clicked => { root.delete-pod(idx); }
                            }
                        }
                    }
                }
            }
        }

        if pod-log != "" : LogViewer {
            text: pod-log;
            vertical-stretch: 1;
        }

        Text {
            text: "Total: " + pods.length;
            font-size: 12px;
            color: Theme.text-muted;
        }
    }
}
