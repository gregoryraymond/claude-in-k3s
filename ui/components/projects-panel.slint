import { Theme } from "../theme.slint";
import { Card } from "card.slint";
import { IconButton } from "icon-button.slint";
import { DataRow } from "data-row.slint";
import { LogViewer } from "log-viewer.slint";
import { CheckBox, ComboBox, LineEdit, ScrollView } from "std-widgets.slint";

export struct ProjectEntry {
    name: string,
    path: string,
    selected: bool,
    base-image-index: int,
    has-custom-dockerfile: bool,
}

export struct LaunchTab {
    name: string,
    status: string,
    log-text: string,
}

export struct LaunchStep {
    label: string,
    status: string,   // "pending", "running", "done", "failed", "skipped"
    message: string,
}

export component ProjectsPanel inherits Rectangle {
    in property <string> projects-dir: "";
    in-out property <[ProjectEntry]> projects: [];
    in property <bool> is-busy: false;
    in property <string> launch-log: "";
    in property <[string]> base-image-options: ["Node.js", "Python", "Rust", "Go", ".NET", "Minimal", "Custom"];
    in property <bool> all-selected: false;
    in property <[LaunchTab]> launch-tabs: [];
    in-out property <int> active-launch-tab: 0;
    in property <[LaunchStep]> launch-steps: [];

    callback browse-folder();
    callback refresh-projects();
    callback launch-selected();
    callback stop-selected();
    callback cancel-launch();
    callback toggle-select-all();
    callback project-toggled(int, bool);
    callback project-image-changed(int, int);

    background: Theme.bg;

    VerticalLayout {
        padding: 24px;
        spacing: 16px;

        Text {
            text: "Projects";
            font-size: 24px;
            font-weight: 700;
            color: Theme.text;
        }

        HorizontalLayout {
            spacing: 8px;

            Rectangle {
                horizontal-stretch: 1;
                height: 34px;
                background: Theme.surface;
                border-radius: 6px;
                border-width: 1px;
                border-color: Theme.border;

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;

                    Text {
                        text: projects-dir != "" ? projects-dir : "Select projects folder...";
                        font-size: 13px;
                        color: projects-dir != "" ? Theme.text : Theme.text-muted;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }

            IconButton {
                label: "Browse";
                clicked => { root.browse-folder(); }
            }

            IconButton {
                label: "Refresh";
                enabled: projects-dir != "";
                clicked => { root.refresh-projects(); }
            }

            IconButton {
                label: all-selected ? "Deselect All" : "Select All";
                enabled: projects.length > 0;
                clicked => { root.toggle-select-all(); }
            }
        }

        Card {
            title: "Project List (" + projects.length + " found)";
            vertical-stretch: 1;

            ScrollView {
                min-height: 200px;

                VerticalLayout {
                    spacing: 0px;

                    for project[idx] in projects: DataRow {
                        alternate: mod(idx, 2) == 1;

                        HorizontalLayout {
                            spacing: 8px;
                            padding-left: 12px;
                            padding-right: 12px;

                            CheckBox {
                                text: project.name;
                                checked: project.selected;
                                horizontal-stretch: 1;
                                toggled => { root.project-toggled(idx, self.checked); }
                            }

                            ComboBox {
                                model: base-image-options;
                                current-index: project.base-image-index;
                                width: 120px;
                                selected(value) => { root.project-image-changed(idx, self.current-index); }
                            }

                            Text {
                                text: project.has-custom-dockerfile ? "(has Dockerfile)" : "";
                                font-size: 11px;
                                color: Theme.text-muted;
                                vertical-alignment: center;
                                min-width: 110px;
                            }
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            alignment: start;

            if !is-busy : IconButton {
                label: "Launch Selected";
                primary: true;
                clicked => { root.launch-selected(); }
            }

            if is-busy : IconButton {
                label: "Cancel";
                destructive: true;
                clicked => { root.cancel-launch(); }
            }

            if !is-busy : IconButton {
                label: "Stop Selected";
                destructive: true;
                clicked => { root.stop-selected(); }
            }
        }

        if launch-tabs.length > 0 : VerticalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            HorizontalLayout {
                spacing: 0px;
                height: 32px;

                for tab[idx] in launch-tabs : Rectangle {
                    min-width: 80px;
                    max-width: 200px;
                    height: 32px;
                    background: idx == active-launch-tab ? Theme.surface : Theme.surface-alt;
                    border-width: 1px;
                    border-color: Theme.border;
                    border-radius: 6px;

                    tab-ta := TouchArea {
                        clicked => { root.active-launch-tab = idx; }
                    }

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 6px;

                        Rectangle {
                            width: 8px;
                            height: 8px;
                            y: 12px;
                            border-radius: 4px;
                            background: tab.status == "Done" ? Theme.success :
                                        tab.status == "Failed" ? Theme.error :
                                        tab.status == "Cancelled" ? Theme.warning :
                                        tab.status == "Building" || tab.status == "Importing" ? Theme.accent :
                                        Theme.text-muted;
                        }

                        Text {
                            text: tab.name;
                            font-size: 11px;
                            color: idx == active-launch-tab ? Theme.text : Theme.text-muted;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }

                // Hardcoded "Logs" tab — uses index -1
                Rectangle {
                    min-width: 80px;
                    max-width: 200px;
                    height: 32px;
                    background: active-launch-tab == -1 ? Theme.surface : Theme.surface-alt;
                    border-width: 1px;
                    border-color: Theme.border;
                    border-radius: 6px;

                    TouchArea {
                        clicked => { root.active-launch-tab = -1; }
                    }

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;

                        Text {
                            text: "Logs";
                            font-size: 11px;
                            color: active-launch-tab == -1 ? Theme.text : Theme.text-muted;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle { horizontal-stretch: 1; }
            }

            // Summary tab (index 0): show traffic-light steps
            if active-launch-tab == 0 && launch-steps.length > 0 : Rectangle {
                vertical-stretch: 1;
                background: Theme.surface;
                border-radius: 6px;
                border-width: 1px;
                border-color: Theme.border;

                ScrollView {
                    VerticalLayout {
                        spacing: 0px;
                        padding-top: 8px;
                        padding-bottom: 8px;

                        for step[sidx] in launch-steps : Rectangle {
                            height: 36px;
                            background: mod(sidx, 2) == 1 ? Theme.surface-alt : transparent;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                spacing: 12px;

                                // Traffic light dot
                                Rectangle {
                                    width: 10px;
                                    height: 10px;
                                    y: 13px;
                                    border-radius: 5px;
                                    background: step.status == "done" ? Theme.success :
                                                step.status == "running" ? Theme.warning :
                                                step.status == "failed" ? Theme.error :
                                                step.status == "skipped" ? Theme.border :
                                                Theme.text-muted;
                                    opacity: step.status == "skipped" ? 0.5 :
                                             step.status == "pending" ? 0.4 : 1.0;
                                }

                                // Step label
                                Text {
                                    text: step.label;
                                    font-size: 13px;
                                    font-weight: 600;
                                    color: step.status == "skipped" ? Theme.text-muted : Theme.text;
                                    vertical-alignment: center;
                                    min-width: 160px;
                                }

                                // Separator dash
                                Text {
                                    text: "—";
                                    font-size: 13px;
                                    color: Theme.text-muted;
                                    vertical-alignment: center;
                                }

                                // Message
                                Text {
                                    text: step.message;
                                    font-size: 13px;
                                    color: step.status == "failed" ? Theme.error : Theme.text-muted;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }
            }

            // Logs tab (index -1): show all combined logs
            if active-launch-tab == -1 : LogViewer {
                text: launch-tabs.length > 0 ? launch-tabs[0].log-text : "";
                vertical-stretch: 1;
            }

            // Project tabs (index > 0): show the project-specific log
            if active-launch-tab > 0 && active-launch-tab < launch-tabs.length : LogViewer {
                text: launch-tabs[active-launch-tab].log-text;
                vertical-stretch: 1;
            }

            // Summary tab with no steps yet — show log directly
            if active-launch-tab == 0 && launch-steps.length == 0 : LogViewer {
                text: launch-tabs.length > 0 ? launch-tabs[0].log-text : "";
                vertical-stretch: 1;
            }
        }
    }
}
