import { Theme } from "../theme.slint";

export component StatusBadge inherits Rectangle {
    in property <string> status: "";

    height: 22px;
    min-width: 64px;
    horizontal-stretch: 0;
    border-radius: 10px;

    border-width: 1px;

    background: {
        if status == "Running" || status == "Healthy" || status == "Found" { return Theme.badge-healthy-bg; }
        if status == "Pending" || status == "Starting" || status == "Degraded" || status == "ContainerCreating" { return Theme.badge-pending-bg; }
        if status == "Failed" || status == "Error" || status == "Missing" || status == "CrashLoopBackOff" || status == "ImagePullBackOff" || status == "ErrImageNeverPull" { return Theme.badge-error-bg; }
        return Theme.surface-alt;
    };

    border-color: {
        if status == "Running" || status == "Healthy" || status == "Found" { return Theme.badge-healthy-border; }
        if status == "Pending" || status == "Starting" || status == "Degraded" || status == "ContainerCreating" { return Theme.badge-pending-border; }
        if status == "Failed" || status == "Error" || status == "Missing" || status == "CrashLoopBackOff" || status == "ImagePullBackOff" || status == "ErrImageNeverPull" { return Theme.badge-error-border; }
        return Theme.border;
    };

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        alignment: center;

        Text {
            text: root.status;
            font-size: 11px;
            font-weight: 700;
            color: {
                if root.status == "Running" || root.status == "Healthy" || root.status == "Found" { return Theme.success; }
                if root.status == "Pending" || root.status == "Starting" || root.status == "Degraded" || root.status == "ContainerCreating" { return Theme.warning; }
                if root.status == "Failed" || root.status == "Error" || root.status == "Missing" || root.status == "CrashLoopBackOff" || root.status == "ImagePullBackOff" || root.status == "ErrImageNeverPull" { return Theme.error; }
                return Theme.text-muted;
            };
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}
