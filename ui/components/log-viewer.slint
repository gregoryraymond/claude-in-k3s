import { Theme } from "../theme.slint";
import { TextEdit } from "std-widgets.slint";

export component LogViewer inherits Rectangle {
    in property <string> text: "";

    background: Theme.log-bg;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.border;
    min-height: 150px;

    VerticalLayout {
        TextEdit {
            text: root.text;
            font-size: 12px;
            read-only: true;
            wrap: word-wrap;
        }
    }
}
