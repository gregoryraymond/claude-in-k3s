import { Theme } from "../theme.slint";
import { TextEdit } from "std-widgets.slint";

export component LogViewer inherits Rectangle {
    in property <string> text: "";
    in-out property <bool> auto-scroll: true;

    background: Theme.log-bg;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.border;
    min-height: 150px;
    clip: true;

    // Auto-scroll: move cursor to end so TextEdit scrolls to bottom
    changed text => {
        if root.auto-scroll {
            te.set-selection-offsets(2147483647, 2147483647);
        }
    }

    // Also scroll when auto-scroll is toggled on or on initial display
    changed auto-scroll => {
        if root.auto-scroll {
            te.set-selection-offsets(2147483647, 2147483647);
        }
    }

    VerticalLayout {
        // Log content area — fills all available space
        te := TextEdit {
            text: root.text;
            font-size: 12px;
            read-only: true;
            wrap: word-wrap;
            vertical-stretch: 1;
        }

        // Status bar — thin separator + auto-scroll toggle
        Rectangle {
            height: 1px;
            background: Theme.border;
        }

        Rectangle {
            height: 24px;
            background: Theme.surface-alt;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                alignment: end;

                TouchArea {
                    width: auto-label.preferred-width + 12px;
                    mouse-cursor: pointer;
                    clicked => { root.auto-scroll = !root.auto-scroll; }

                    auto-label := Text {
                        text: root.auto-scroll ? "Auto-scroll: ON" : "Auto-scroll: OFF";
                        font-size: 11px;
                        color: root.auto-scroll ? Theme.accent : Theme.text-muted;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
